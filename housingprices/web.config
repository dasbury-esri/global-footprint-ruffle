<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <httpRedirect enabled="false" />
        <httpErrors errorMode="DetailedLocalOnly" />
        <staticContent>
            <mimeMap fileExtension=".swz" mimeType="application/x-swz" />
        </staticContent>
    </system.webServer>
</configuration>
